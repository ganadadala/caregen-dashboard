# 한국투자증권 KIS Developers 에서 발급받은 키를 입력하세요.
# https://apiportal.koreainvestment.com  →  앱 등록 후 APP Key / APP Secret 발급

KIS_APPKEY=키입력
KIS_APPSECRET=키입력

# 종목코드 (케어젠 = 214370). 다른 종목도 화면에서 변경 가능.
STOCK_CODE=214370

# (선택) KOSDAQ 제약 업종지수 코드. 입력하면 차트에 비교선(점선)이 추가됩니다.
# 미입력 시 종목선(CG)만 표시되며 나머지는 정상 동작합니다.
KOSDAQ_PHARM_CODE=

# (선택) OPEN DART 인증키. 입력 시 공시 카드에 DART 공시가 자동 표시됩니다.
# 무료 발급: https://opendart.fss.or.kr  →  인증키 신청/관리
DART_API_KEY=키입력

# 실전투자 도메인 (기본값). 모의투자는 https://openapivts.koreainvestment.com:29443
KIS_BASE_URL=https://openapi.koreainvestment.com:9443

# (선택) Anthropic API 키 - '뉴스 채우기' 버튼 사용 시 필요합니다.
# 발급: https://console.anthropic.com  →  API Keys
ANTHROPIC_API_KEY=키입력
